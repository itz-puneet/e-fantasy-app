# Copy this file to ".env" and fill in your own Supabase values.
# Find both in the Supabase dashboard -> Project Settings -> API.
# Use the BASE project URL (no "/rest/v1/" on the end).
#
# These are EXPO_PUBLIC_ variables, so they are embedded in the app bundle.
# The anon key is safe to expose (Row-Level Security protects your data) —
# but never put your Supabase SERVICE ROLE key in this app.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
